{{#results}}
  <div class="result"> 
    <h2>{{word}}</h2>
    <p>{{definition}}</p>
    {{#foundWords}}
      <div class="found-words">
        <button class="found-word" id="{{.}}">
          <b>{{.}}</b>: <span>{{foundWordDefinition}}</span>
        </button>
      </div>
    {{/foundWords}}
  </div>
{{/results}}
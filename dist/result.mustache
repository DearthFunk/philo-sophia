{{#results}}
  <div class="result"> 
    <h2>{{word}}</h2>
    <p>{{definition}}</p>
    {{#foundWords}}
      <div class="found-words">
        <div class="found-word">
          <span>{{.}}</span>: {{foundWordDefinition}}
        </div>
      </div>
    {{/foundWords}}
  </div>
{{/results}}